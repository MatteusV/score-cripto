    {
      "id": "flow-title",
      "type": "text",
      "x": 283.3240884211855,
      "y": 941.6792917175944,
      "width": 600,
      "height": 22,
      "text": "🔄 Fluxo Principal: Consulta de Score",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
