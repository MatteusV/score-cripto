generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model AnalysisRequest {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  publicId      Int?           @map("public_id")
  chain         String
  address       String
  status        AnalysisStatus @default(PENDING)
  requestedAt   DateTime       @default(now()) @map("requested_at")
  completedAt   DateTime?      @map("completed_at")
  failedAt      DateTime?      @map("failed_at")
  failureReason String?        @map("failure_reason")

  // Resultado inline (preenchido ao consumir wallet.score.calculated)
  score           Int?
  confidence      Float?
  reasoning       String?
  positiveFactors Json?   @map("positive_factors")
  riskFactors     Json?   @map("risk_factors")
  modelVersion    String? @map("model_version")
  promptVersion   String? @map("prompt_version")

  translations AnalysisTranslation[]

  @@unique([userId, publicId])
  @@index([userId])
  @@index([userId, publicId])
  @@index([status])
  @@index([chain, address])
  @@index([userId, chain, address])
  @@index([userId, completedAt])
  @@map("analysis_requests")
}

model AnalysisTranslation {
  id              String          @id @default(cuid())
  analysisId      String          @map("analysis_id")
  locale          String
  reasoning       String?
  positiveFactors Json?           @map("positive_factors")
  riskFactors     Json?           @map("risk_factors")
  translatedAt    DateTime        @default(now()) @map("translated_at")
  analysis        AnalysisRequest @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@unique([analysisId, locale])
  @@index([analysisId])
  @@map("analysis_translations")
}

model UserAnalysisCounter {
  userId  String @id @map("user_id")
  counter Int    @default(0)

  @@map("user_analysis_counters")
}
