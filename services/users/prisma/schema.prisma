generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Models will be defined in the schema design issue (score-cripto-4jy)
// Temporary model to allow prisma generate to succeed
model ConfigEntry {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())

  @@map("config_entries")
}
