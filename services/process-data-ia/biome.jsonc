{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/vitest"],
  "files": {
    "includes": [
      "src/**",
      "!src/tests/e2e",
      "!src/generated",
      "!src/.generated-stuck"
    ]
  },
  "linter": {
    "rules": {
      "suspicious": {
        "useAwait": "off"
      }
    }
  }
}
