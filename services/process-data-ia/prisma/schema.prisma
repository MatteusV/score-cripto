generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model AnalysisRequest {
  id                String         @id @default(cuid())
  userId            String         @map("user_id")
  chain             String
  address           String
  status            AnalysisStatus @default(PENDING)
  walletContextHash String         @map("wallet_context_hash")
  requestedAt       DateTime       @default(now()) @map("requested_at")
  processingAt      DateTime?      @map("processing_at")
  completedAt       DateTime?      @map("completed_at")
  failedAt          DateTime?      @map("failed_at")
  failureReason     String?        @map("failure_reason")

  processedData ProcessedData?

  @@index([userId])
  @@index([userId, requestedAt])
  @@index([status])
  @@index([chain, address])
  @@index([walletContextHash])
  @@map("analysis_requests")
}

model ProcessedData {
  id                  String   @id @default(cuid())
  analysisRequestId   String   @unique @map("analysis_request_id")
  userId              String   @map("user_id")
  chain               String
  address             String
  score               Int
  confidence          Float
  reasoning           String
  positiveFactors     Json     @map("positive_factors")
  riskFactors         Json     @map("risk_factors")
  modelVersion        String   @map("model_version")
  promptVersion       String   @map("prompt_version")
  tokensUsed          Int      @map("tokens_used")
  cost                Float
  inferenceDurationMs Int      @map("inference_duration_ms")
  validUntil          DateTime @map("valid_until")
  createdAt           DateTime @default(now()) @map("created_at")

  analysisRequest AnalysisRequest @relation(fields: [analysisRequestId], references: [id])

  @@index([userId])
  @@index([chain, address])
  @@index([validUntil])
  @@map("processed_data")
}
