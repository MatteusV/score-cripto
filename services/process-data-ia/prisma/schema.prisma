generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProcessedData {
  id                  String   @id @default(cuid())
  analysisRequestId   String   @map("analysis_request_id")
  userId              String   @map("user_id")
  chain               String
  address             String
  score               Int
  confidence          Float
  reasoning           String
  positiveFactors     Json     @map("positive_factors")
  riskFactors         Json     @map("risk_factors")
  modelVersion        String   @map("model_version")
  promptVersion       String   @map("prompt_version")
  tokensUsed          Int      @map("tokens_used")
  cost                Float
  inferenceDurationMs Int      @map("inference_duration_ms")
  walletContextHash   String   @map("wallet_context_hash")
  validUntil          DateTime @map("valid_until")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([chain, address, walletContextHash, validUntil])
  @@map("processed_data")
}
