    "ai": "^6.0.0",
    "amqplib": "^0.10.5",
    "pg": "^8.20.0",
    "prisma": "^6.19.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/amqplib": "^0.10.6",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "ultracite": "7.4.0",
    "vitest": "^3.1.0"
