{
  "title": "AI Cost & Usage",
  "uid": "score-cripto-ai-cost",
  "version": 1,
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "tags": ["score-cripto", "ai", "cost"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total AI Cost (last 24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(ai_cost_usd_total[24h]))",
          "legendFormat": "USD"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Tokens Used (last 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(ai_tokens_total[1h]))",
          "legendFormat": "tokens"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cost Rate ($/min) by Model",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (model) (rate(ai_cost_usd_total[5m])) * 60",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 6 } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tokens/min by Model & Type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (model, type) (rate(ai_tokens_total[5m])) * 60",
          "legendFormat": "{{model}} ({{type}})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Token Split: Prompt vs Completion (last 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (type) (increase(ai_tokens_total[1h]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cumulative Cost (USD)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (model) (ai_cost_usd_total)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } }
    }
  ]
}
